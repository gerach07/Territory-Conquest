# Territory Conquest Server Environment Variables
# Copy this file to .env and fill in the values

# Port to run the server on (default: 3000)
PORT=3000

# Comma-separated list of allowed CORS origins
# For local development:
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:5000

# For production, add your Railway/hosting URL:
# ALLOWED_ORIGINS=https://your-app.up.railway.app

# Node environment (set automatically by npm scripts)
# NODE_ENV=development
